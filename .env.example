# Vercel Postgres: Dashboard → Storage → seu banco → .env.local → copiar POSTGRES_URL_NON_POOLING
# Use NON_POOLING: psycopg usa conexões persistentes, incompatível com o pooler serverless
DATABASE_URL=postgres://[user]:[password]@[host].us-east-1.aws.neon.tech/[dbname]?sslmode=require

SCRAPE_CRON_MORNING=0 6 * * *
SCRAPE_CRON_EVENING=0 18 * * *
PLAYWRIGHT_HEADLESS=true
SCRAPE_CONCURRENCY=3
SCRAPE_DELAY_MIN_SEC=2
SCRAPE_DELAY_MAX_SEC=6
ALERT_DROP_THRESHOLD=-5.0
ALERT_RISE_THRESHOLD=10.0
LOG_LEVEL=INFO
